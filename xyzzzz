void tabChangeEvent(event) {
  if (html.window.document.visibilityState == "visible") {
    prevWebViewHidden = webViewHidden;
    webViewHidden = false;
  } else {
    Hive.box(hiveBoxNameTime).put('pausedtime', DateTime.now());
    prevWebViewHidden = webViewHidden;
    webViewHidden = true;
  }
}

Future<void> getAndSaveLocalUserNameInMemory() async {
  try {
    Box box = await Hive.openBox<UserProfileLocal>(hiveBoxUserProfile);
    UserProfileLocal? localProfile = box.get(hiveBoxUserProfileRecordString);
    String userId = "";
    if (localProfile != null) {
      userId = localProfile.userId;
    } else {
      userId = "${const UuidV4().generate()}_$localWordItUsernameSuffix";
      await box.put(
          hiveBoxUserProfileRecordString, UserProfileLocal(userId: userId));
    }
    CachedData().userIdLocal = userId;
  } catch (e) {
    rethrow;
  }
}

