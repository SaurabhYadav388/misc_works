Widget gameWidget(Size size, AppState state, BuildContext context,
    [Orientation? forcedOrientation]) {
  // context.read<AppBloc>().add(ConnectToFirebase());
  // return RegisterView(size: size);
  // return ResultView(
  //   result: dummyStats,
  //   size: size,
  // );

  //////////////////////////
  if (forcedOrientation != null && forcedOrientation == Orientation.portrait) {
    return portraitGame(size, state, context);
  }
  final portrait = MediaQuery.of(context).orientation == Orientation.portrait;
  if (portrait) {
    return portraitGame(size, state, context);
  }
  return landscapeGame(size, state, context);
}

class HomePage extends StatefulWidget {
  const HomePage({super.key});

  @override
  State<HomePage> createState() => _HomePageState();
}

class _HomePageState extends State<HomePage> {
  void windowResizeEvent(Event e) {}
  Future<String>? _initialDataFuture;

  @override
  void initState() {
    // html.window.addEventListener('beforeunload', (event) async {
    //   event.preventDefault();
    //   return 'Are you sure you want to leave?';
    // });

    super.initState();
    _initialDataFuture = run();
  }

  Future<String> run() async {
    try {
      await getAndSaveLocalUserNameInMemory();
      await Hive.openBox<StatData>(hiveBoxName);
      await Hive.openBox<UserSaveLocal>(hiveBoxNameSave);
      await CountryGetter().getCountryAsync();
      await DeviceInfo().initPlatformState();
      DataStore store = AuthService.backend().getDataStore();
      if (store is FireDataStore) {
        UserProfile profile = await store.getUserProfile();
        CachedData().profile = profile;
      }

      GameUtil().setBox();
      GameUtil().setSaveBox();

      JsInteropService().setMailService();
      DiagnosticWordIt().init();
      SaveLoadManager().init();
      return "";
    } catch (e) {
      return e.toString();
    }
  }

  @override
  Widget build(BuildContext context) {
    Size size = MediaQuery.of(context).size;
    double desktopClampedWidth = size.height * pcVersionAspectRatio;
    desktopClampedWidth = size.width;
    size = Size(
      isDesktop ? desktopClampedWidth : size.width,
      size.height,
    );
    return FutureBuilder(
      future: _initialDataFuture,
      builder: (context, snapshot) {
        if (snapshot.connectionState == ConnectionState.done) {
          if (snapshot.hasError) {
            return const LoadingIndicatorView(error: "Something went wrong");
          } else if (snapshot.hasData) {}
          return BlocProvider(
            create: (context) => AppBloc(),
            child: Scaffold(
              body: BlocConsumer<AppBloc, AppState>(
                listener: (context, state) {
                  if (state.isLoading) {
                    LoadingScreen.instance().show(
                      context: context,
                      text: waitString,
                    );
                  } else {
                    LoadingScreen.instance().hide();
                  }
                  if (state.errors != null) {
                    handleErrors(
                      size.width,
                      isDesktop,
                      context,
                      state.errors!,
                    );
                  }
                },
                buildWhen: (previous, current) {
                  bool ret = previous != current ||
                      (prevWebViewHidden != webViewHidden);
                  return ret;
                },
                builder: (context, state) {
                  final bool isTablet = size.shortestSide >= 600;
                  if (isMobile) {
                    return isTablet
                        ? gameWidget(size, state, context)
                        : gameWidget(size, state, context);
                  }
                  //desktop
                  else {
                    if (isDesktop) {
                      return gameWidget(
                          size, state, context, Orientation.portrait);
                    }
                    // mobile web
                    else {
                      return Container(
                        color: Colors.blue,
                      );
                    }
                  }
                },
              ),
            ),
          );
        } else {
          return const LoadingIndicatorView(
            error: "Loading",
          );
        }
      },
    );
  }
}

