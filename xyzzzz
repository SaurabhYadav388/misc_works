void handleErrors(
    double width, bool desktop, BuildContext context, Errors error) {
  String title = '';
  String content = '';
  switch (error) {
    case Errors.unableToFetchLocalUserId:
      title = 'Error';
      content = "Local user id not found";

      break;
    case Errors.unableToFetchFirebaseUserId:
      title = 'Error';
      content = "Online user id not found";

      break;
    case Errors.textCopiedToClipboard:
      title = 'Update';
      content = "Text copied to clipboard";

      break;
    case Errors.puzzleNotUploadedYet:
      title = "Error";
      content = "Puzzle yet to go live. Please check again in some time.";
    case Errors.puzzleNotCompletedSoStatsCannotBeShared:
      title = errorTitleSomethingWentWrong;
      content = errorDescCannotBeShared;

      break;

    case Errors.failedToConnectToFirebase:
      title = errorTitleSomethingWentWrong;
      content = errorFirebaseConnFailed;
      break;
    case Errors.notEnoughGamesForLeaderboard:
      title = errorTitleError;
      content = minMatchLeaderboardError;
      break;
    case Errors.invalidBackToPuzzle:
      title = invalidBackToPuzzleTitle;
      content = invalidBackToPuzzleContent;
      break;
    case Errors.invalidPuzzle:
      title = invalidPuzzleTitle;
      content = invalidPuzzleContent;
      break;
    case Errors.puzzleGameplayError:
      title = errorTitleSomethingWentWrong;
      content = errorContentSomethingWentWrongGameplayError;
      break;
    case Errors.puzzleNotAvailableForToday:
      title = noPuzzleFound;
      content = nopuzzleAvailableToday;
    case Errors.failedToLoadDataFromFirebase:
      title = "Error";
      content = notAbleToLoadData;
    default:
  }
  if (error == Errors.leaderboardHelp) {
    final size = Size(width, MediaQuery.of(context).size.height);

    showModalBottomSheet(
      isScrollControlled: true,
      isDismissible: true,
      constraints: BoxConstraints(
          maxWidth: size.width,
          maxHeight: size.height * leaderboardHelpDialogHeightRatio),
      backgroundColor: Colors.white,
      shape: const RoundedRectangleBorder(
        borderRadius: BorderRadius.vertical(top: Radius.circular(20.0)),
      ),
      context: context,
      builder: (context) {
        return LeaderboardHelpPageBottomSheet().showBottomSheet(context, size);
      },
    ).then(
      (value) => context.read<AppBloc>().add(
            ToggleDialog(
              show: false,
              dialog: DialogWordIt.leaderboard,
            ),
          ),
    );
  } else if (error == Errors.help) {
    final size = Size(width, MediaQuery.of(context).size.height);

    showModalBottomSheet(
      isScrollControlled: true,
      isDismissible: true,
      constraints: BoxConstraints(
          maxWidth: size.width,
          maxHeight: size.height * GameUtil().getHowToPlaySheetHeight()),
      backgroundColor: Colors.white,
      shape: const RoundedRectangleBorder(
        borderRadius: BorderRadius.vertical(top: Radius.circular(20.0)),
      ),
      context: context,
      builder: (context) {
        return HowToPlayPageBottomSheet().showBottomSheet(context, size);
      },
    ).then(
      (value) => context.read<AppBloc>().add(
            ToggleDialog(
              show: false,
              dialog: DialogWordIt.help,
            ),
          ),
    );
  } else {
    showGenericDialog(
        context: context,
        dialogName: DialogWordIt.none,
        title: title,
        content: content,
        optionBuilder: () => {'ok': true});
  }
}

Widget portraitGame(Size size, AppState state, BuildContext context) {
  TimeService().getCurrentTimeStampIndia();

  if (state.currentScreen == Screen.blankScreen) {
    context.read<AppBloc>().add(ConnectToFirebase());
    return const BlankView();
  } else if (state.currentScreen == Screen.loadingScreen) {
    return LoadingView(
      error: state.errors,
      size: size,
      fetchedPuzzle: state.fetchedPuzzle,
      callback: () {
        return;
      },
    );
  } else if (state.currentScreen == Screen.leaderboard) {
    return LeaderboardView(
      size: size,
      onlineData: state.leaderboardData ?? LeaderboardDataOnline.empty(),
    );
  } else if (state.currentScreen == Screen.resetPassword) {
    return CreatePasswordView(size: size);
  } else if (state.currentScreen == Screen.otp) {
    return VerifyOtpView(size: size);
  } else if (state.currentScreen == Screen.login) {
    return LoginView(size: size);
  } else if (state.currentScreen == Screen.signup) {
    return RegisterView(size: size);
  } else if (state.currentScreen == Screen.chooseUsername) {
    return CreateUsernameView(size: size);
  } else if (state.currentScreen == Screen.gameplayScreen) {
    return GameplayView(
      firstCol: state.rowStartCol,
      initialTimerValue: state.initialTimerValue,
      letterBoxes: state.letterBoxes,
      mainGridLetters: state.gridLetters!,
      tapMode: state.activeRowArrow == -1 ? false : true,
      rows: state.rowCount,
      zoom: state.zoomOn ?? false,
      cols: state.colCount,
      invalidEntry: state.invalidEntry,
      specialColumn: state.specialColumn,
      gridCellExtraInfoList: state.gridExtraInfoList,
      width: size.width,
    );
  } else if (state.currentScreen == Screen.resultScreen) {
    return ResultView(
      result: state.result,
      size: size,
    );
  } else if (state.currentScreen == Screen.welcomeScreen) {
    return WelcomeView().getWelcomeView(size, context, state.result, true);
  } else if (state.currentScreen == Screen.puzzleNotUploadedScreen) {
    return WelcomeView().getWelcomeView(size, context, state.result, false);
  }
  return Container();
}

