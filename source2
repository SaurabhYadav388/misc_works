#include <SFML/Graphics.hpp>
#include<SFML/Window.hpp>
#include<SFML/System.hpp>
#include<SFML/Audio.hpp>
#include<SFML/Network.hpp>
#include<iostream>

using namespace sf;

int main()
{
    RenderWindow window(VideoMode(1000, 600), "SFML works!");
    window.setFramerateLimit(60);//

    /*CircleShape shape(50.0f);
    shape.setFillColor(Color::Green);
    float dirX=cosf(3.14f/2.0f);
    float dirY=sinf(3.14f/2.0f);
    float velocity = 10.0f;*/

    //********Shooting projectiles in SFML / C++ in direction of mouse
    ConvexShape arrow;
    arrow.setPointCount(7);
    arrow.setPoint(0, Vector2f(0, 1));
    arrow.setPoint(1, Vector2f(30, 1));
    arrow.setPoint(2, Vector2f(35, 3));
    arrow.setPoint(3, Vector2f(40, 0));
    arrow.setPoint(4, Vector2f(35, -3));
    arrow.setPoint(5, Vector2f(30, -1));
    arrow.setPoint(6, Vector2f(0, -1));
    arrow.setFillColor(Color::Green);

    arrow.setPosition(100, 300);

    arrow.scale(3, 3);

    sf::VertexArray trajectoryLine(sf::LinesStrip);

    while (window.isOpen()) {
        Event event;
        while (window.pollEvent(event)) {
            if (event.type == Event::Closed)
                window.close();

            //if (event.type == Event::MouseButtonPressed ) {
                trajectoryLine.clear();

                float angle = atan2f(Mouse::getPosition(window).y - arrow.getPosition().y,
                                        Mouse::getPosition(window).x - arrow.getPosition().x);

                
                float speed;
                if(Mouse::getPosition(window).x>arrow.getPosition().x)
                    speed = 0.1f * (window.getSize().x -  Mouse::getPosition(window).x);
                else
                {
                    speed = 0;
                }
                arrow.setRotation(speed* (- angle) );

                // Simulate the projectile path
                for (float t = 0; t <= 10.0f; t += 0.1f) {
                    float x = speed * t * std::cosf(angle);
                    float y = speed * t * std::sinf(angle) - 0.5f * 9.8f * t * t;

                    Vector2f arrowheadPosition = arrow.getTransform().transformPoint(arrow.getPoint(3));
                    //trajectoryLine.append(sf::Vertex(sf::Vector2f(arrow.getPosition().x + arrow.getGlobalBounds().width + x, arrow.getPosition().y - y), sf::Color::Red));
                    trajectoryLine.append(sf::Vertex(sf::Vector2f(arrowheadPosition.x + x, arrowheadPosition.y - y), sf::Color::Red));

                }
            //}
        }

        window.clear();

        // Draw arrow
        window.draw(arrow);

        // Draw trajectory line
        window.draw(trajectoryLine);

        window.display();
    }

    return 0;
}
