#define ASIO_STANDALONE
 
#include<asio.hpp>
#include<asio/ts/buffer.hpp>
#include<asio/ts/internet.hpp>
#include<chrono>
 
 
std::vector<char> vbuffer(1024);
 
void GrabSomeData(asio::ip::tcp::socket& socket) {
 
	socket.async_read_some(asio::buffer(vbuffer.data(), vbuffer.size()), [&](std::error_code ec, std::size_t length) {
 
		if (!ec) {
 
			std::cout << "\nReading";
 
			for (int i = 0; i < length; i++) {
				std::cout << vbuffer[i];
 
				GrabSomeData(socket);
			}
		}
	});
}
 
int main() {
	asio::error_code ec;
 
	asio::io_context context;
 
	asio::io_context::work idleWork(context);
 
	std::thread thrContext = std::thread([&]() { context.run();});
 
		asio::ip::tcp::endpoint endpoint(asio::ip::make_address("10.65.13.2", ec), 3000);
 
		asio::ip::tcp::socket socket(context);
 
		socket.connect(endpoint, ec);
 
 
		if (!ec) {
			std::cout << "Connected!" << std::endl;
		}
 
		else {
			std::cout << "Failed to connect to address:\n" << ec.message() << std::endl;
		}
 
		if (socket.is_open()) {
 
			GrabSomeData(socket);
 
			std::string message = "Hello Nodejs\n";
 
			socket.write_some(asio::buffer(message.data(), message.size()), ec);
 
			bool msg = true;
			while (msg) {
 
				
				std::cin >> message;
 
				socket.write_some(asio::buffer(message.data(), message.size()), ec);
 
			}
			//using namespace std::chrono_literals;
			//std::this_thread::sleep_for(20000ms);
 
			context.run();
 
		}
 
		if(thrContext.joinable()) thrContext.join();
 
		//system("pause");
	return 0;
}

