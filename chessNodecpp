const express = require('express');
const http = require('http');
const socketIO = require('socket.io');
const net = require('net');
 
// Create the Express app and HTTP server
const app = express();
const httpServer = http.createServer(app);
const io = socketIO(httpServer);
 
// Serve the frontend files on port 3000
app.use(express.static('public')); // Assuming your frontend files are in the 'public' directory
httpServer.listen(3000, () => {
  console.log('Frontend server listening on port 3000');
});
 
// Create the TCP server for the C++ backend on port 4000
const tcpServer = net.createServer((cppBackendSocket) => {
  console.log('C++ backend connected');
 
  cppBackendSocket.on('data', (dataFromCppBackend) => {
    console.log('Received data from C++ backend:', dataFromCppBackend.toString());
 
    // Process the data and emit it to the frontend using Socket.IO
    io.emit('dataFromBackend', dataFromCppBackend.toString());
  });
 
  cppBackendSocket.on('end', () => {
    console.log('C++ backend disconnected');
  });
 
  // Listen for data from the frontend using Socket.IO
  io.on('connection', (frontendSocket) => {
    console.log('Frontend connected');
 
    frontendSocket.on('dataFromFrontend', (dataFromFrontend) => {
      console.log('Received data from frontend:', dataFromFrontend);
 
      // Send the data to the C++ backend over the TCP socket
      cppBackendSocket.write(dataFromFrontend);
    });
 
    frontendSocket.on('disconnect', () => {
      console.log('Frontend disconnected');
    });
  });
});
 
tcpServer.listen(4000, () => {
  console.log('Backend server listening on port 4000');
});
 
 
