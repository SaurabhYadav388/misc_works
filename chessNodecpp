#include <iostream>
#include <vector>
 
 
enum Colors { WHITE, BLACK };
 
class ChessPiece
{
	std::pair<int, int> position;
	bool isAlive;
	Colors color;
 
public:
	ChessPiece(std::pair<int, int> position, bool isAlive, Colors color)
	{
		this->position = position;
		this->isAlive = isAlive;
		this->color = color;
	}
 
	std::pair<int,int> getPosition()
	{
		return position;
	}
	bool getIsAlive()
	{
		return isAlive;
	}
	Colors getColor()
	{
		return color;
	}
	virtual std::vector<std::pair<int, int>> movementRule() = 0;
};


