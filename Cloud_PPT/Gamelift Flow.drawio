        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n!define RECTANGLE class\n\nRECTANGLE GameClient {\n    +Request Matchmaking()\n    +Connect to Game Server()\n    +Send Player Actions()\n    +Receive Updates()\n}\n\nRECTANGLE GameLift {\n    +FlexMatch Service\n    +Create Game Session()\n    +Provide Connection Info()\n    +Monitor Session Health()\n}\n\nRECTANGLE GameServer {\n    +Process Actions()\n    +Send Updates()\n    +Receive Player Actions()\n}\n\nRECTANGLE GameLiftConsole {\n    +Create Fleet()\n    +Deploy Game Server Build()\n}\n\nRECTANGLE Fleet {\n    +Auto-scaling()\n}\n\nGameClient --&gt; GameLift : Request Matchmaking\nGameLift --&gt; GameServer : Create Game Session\nGameLift --&gt; GameClient : Provide Connection Info\nGameClient --&gt; GameServer : Connect to Game Server\nGameClient --&gt; GameServer : Send Player Actions\nGameServer --&gt; GameClient : Send Updates\nGameLift ..&gt; GameServer : Monitor Session Health\n\nGameLiftConsole --&gt; Fleet : Create Fleet\nFleet --&gt; GameServer : Auto-scaling\n\nRECTANGLE AWSServices {\n    +S3 Storage\n    +DynamoDB Database\n    +CloudWatch Monitoring\n}\n\nGameServer --&gt; AWSServices : Use Services\nGameLift ..&gt; AWSServices : Monitor Session Health\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="tUJJx3g9K0P2CX-wzsBw-28">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" parent="1" vertex="1">
            <mxGeometry x="145" y="800" width="1189" height="640" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\npackage \&quot;Game Client\&quot; {\n    actor Player\n    component \&quot;Game Client Application\&quot; as Client\n}\n\npackage \&quot;Amazon GameLift\&quot; {\n    package \&quot;Matchmaking\&quot; {\n        component \&quot;FlexMatch Service\&quot; as FlexMatch\n    }\n    package \&quot;Session Management\&quot; {\n        component \&quot;Game Session Creation\&quot; as SessionCreation\n        component \&quot;Game Session Placement\&quot; as SessionPlacement\n        component \&quot;Queue Management\&quot; as Queue\n    }\n    package \&quot;Server Management\&quot; {\n        component \&quot;Fleet Management\&quot; as FleetMgmt\n        component \&quot;Game Server\&quot; as GameServer\n        component \&quot;Auto-scaling\&quot;\n        component \&quot;Server Health Monitoring\&quot; as ServerHealth\n    }\n}\n\npackage \&quot;AWS Services\&quot; {\n    component \&quot;S3 Storage\&quot; as S3\n    component \&quot;DynamoDB Database\&quot; as DynamoDB\n    component \&quot;CloudWatch Monitoring\&quot; as CloudWatch\n}\n\nPlayer --&gt; Client : Initiate Matchmaking Request\nClient --&gt; FlexMatch : Send Matchmaking Request\nFlexMatch --&gt; SessionCreation : Create Game Session\nSessionCreation --&gt; SessionPlacement : Place Game Session in Fleet\nSessionPlacement --&gt; Queue : Manage Placement Queues\nQueue --&gt; FleetMgmt : Determine Optimal Fleet\nFleetMgmt --&gt; GameServer : Allocate Game Server\nGameServer --&gt; Client : Provide Connection Info\nClient --&gt; GameServer : Connect to Game Server\nClient --&gt; GameServer : Send Player Actions\nGameServer --&gt; Client : Send Updates\nServerHealth --&gt; GameServer : Monitor Server Health\nServerHealth --&gt; CloudWatch : Send Health Metrics\n\nGameServer --&gt; S3 : Store Game Data\nGameServer --&gt; DynamoDB : Access Player Data\nCloudWatch --&gt; ServerHealth : Monitor Health Data\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="tUJJx3g9K0P2CX-wzsBw-32">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" parent="1" vertex="1">
            <mxGeometry x="20" y="1510" width="1532.87" height="1140" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\npackage \&quot;Game Client\&quot; {\n    actor Player\n    component \&quot;Game Client Application\&quot; as Client\n}\n\npackage \&quot;Amazon GameLift\&quot; {\n    package \&quot;Matchmaking\&quot; {\n        component \&quot;FlexMatch Service\&quot; as FlexMatch\n    }\n    package \&quot;Session Management\&quot; {\n        component \&quot;Game Session Creation\&quot; as SessionCreation\n        component \&quot;Game Session Placement\&quot; as SessionPlacement\n        component \&quot;Queue Management\&quot; as Queue\n    }\n    package \&quot;Server Management\&quot; {\n        component \&quot;Fleet Management\&quot; as FleetMgmt\n        package \&quot;Fleets\&quot; {\n            component \&quot;Fleet 1\&quot;\n            component \&quot;Fleet 2\&quot;\n        }\n        component \&quot;Game Server\&quot; as GameServer\n        component \&quot;Auto-scaling\&quot;\n        component \&quot;Server Health Monitoring\&quot; as ServerHealth\n    }\n    package \&quot;Game Build Deployment\&quot; {\n        component \&quot;Game Build\&quot; as GameBuild\n    }\n}\n\npackage \&quot;AWS Services\&quot; {\n    component \&quot;EC2 Instance\&quot; as EC2\n    component \&quot;S3 Storage\&quot; as S3\n    component \&quot;DynamoDB Database\&quot; as DynamoDB\n    component \&quot;CloudWatch Monitoring\&quot; as CloudWatch\n}\n\nPlayer --&gt; Client : Initiate Matchmaking Request\nClient --&gt; FlexMatch : Send Matchmaking Request\nFlexMatch --&gt; SessionCreation : Create Game Session\nSessionCreation --&gt; SessionPlacement : Place Game Session in Fleet\nSessionPlacement --&gt; Queue : Manage Placement Queues\nQueue --&gt; FleetMgmt : Determine Optimal Fleet\nFleetMgmt --&gt; Fleet1 : Allocate Game Server\nFleetMgmt --&gt; Fleet2 : Allocate Game Server\nFleetMgmt --&gt; GameBuild : Deploy Game Build\nGameBuild --&gt; EC2 : Run on EC2 Instance\nEC2 --&gt; GameServer : Host Game Server\nGameServer --&gt; Client : Provide Connection Info\nClient --&gt; GameServer : Connect to Game Server\nClient --&gt; GameServer : Send Player Actions\nGameServer --&gt; Client : Send Updates\nServerHealth --&gt; GameServer : Monitor Server Health\nServerHealth --&gt; CloudWatch : Send Health Metrics\n\nGameServer --&gt; S3 : Store Game Data\nGameServer --&gt; DynamoDB : Access Player Data\nCloudWatch --&gt; ServerHealth : Monitor Health Data\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="tUJJx3g9K0P2CX-wzsBw-33">
