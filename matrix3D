#include <iostream>
#include <vector>

using namespace std;

template <typename T>
class Matrix {
protected:
    int rows;
    int cols;
    vector<vector<T>> data;
public:
    int getRows()
    {
        return rows;
    }
    int getCols()
    {
        return cols;
    }
    //param. constructor
    Matrix(int rows, int cols)
    {
        this->rows = rows;
        this->cols = cols;
        data = vector<vector<T>>(rows, vector<T>(cols, 0));
    }

    //returns if is square Matrix
    bool isSquare()
    {
        return rows == cols;
    }
    void setter(int rowInd, int colInd, T value)
    {
        data[rowInd][colInd] = value;
    }
    //assign data(stl vector) to our Matrix
    void assignVector(vector<vector<T>>& assignVector)
    {
        for (int i = 0; i < assignVector.size(); i++)
        {
            for (int j = 0; j < assignVector[0].size(); j++)
                this->setter(i, j, assignVector[i][j]);
        }
    }
    T getValue(int rowInd, int colInd)
    {
        return data[rowInd][colInd];
    }
    //displaying matrix content
    void print()
    {
        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
                cout << round(data[i][j]) << "  ";

            cout << "\n";
        }
        cout << "\n";
    }

    //addition operator
    Matrix<T> operator +(const Matrix<T>& second)
    {
        Matrix<T> res(rows, cols);
        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
                res.data[i][j] = this->data[i][j] + second.data[i][j];
        }
        return res;
    }

    //subtraction operator
    Matrix<T> operator -(const Matrix<T>& second)
    {
        Matrix<T> res(rows, cols);
        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
                res.data[i][j] = this->data[i][j] - second.data[i][j];
        }
        return res;
    }

    //multiplication operator
    Matrix<T> operator *(const Matrix<T>& second)
    {
        if (cols != second.rows)
            cout << "\nMatrix Multiplication not possible\n";

        Matrix<T> res(rows, second.cols);

        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < second.cols; j++)
            {
                res.data[i][j] = 0;//init to zero
                for (int k = 0; k < cols; k++)
                {
                    res.data[i][j] += this->data[i][k] * second.data[k][j];

                }

            }
        }
        return res;
    }

    //scalar multiplication operator
    Matrix<T> operator *(const int scale)
    {
        Matrix<T> res(rows, cols);

        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
            {
                res.data[i][j] = data[i][j] * scale;
            }
        }
        return res;
    }

    //transposing matrix
    Matrix<T> transpose()
    {
        Matrix<T> transp(cols, rows);
        for (int i = 0; i < rows; i++)
            for (int j = 0; j < cols; j++)
                transp.data[j][i] = data[i][j];

        return transp;
    }
    //calculates cofactor of element at iRow and jCol coordinate
    T cofactor(int iRow, int jCol)
    {
        if (!isSquare())
            cout << "\nThe matrix should be square Matrix to calculate CoFactor\n";

        T result = 0;

        Matrix<T> subMatrix(rows - 1, cols - 1);
        int subRowIndex = 0;
        for (int i = 0; i < rows; i++)
        {
            if (i == iRow)continue;

            int subColIndex = 0;

            for (int j = 0; j < cols; j++)
            {

                if (j == jCol)continue;

                subMatrix.setter(subRowIndex, subColIndex, data[i][j]);
                subColIndex++;
            }
            subRowIndex++;
        }
        result = pow(-1, iRow + jCol) * subMatrix.determinant();
        return result;
    }
    T determinant()
    {
        if (!isSquare())
            cout << "\nThe matrix should be square Matrix to calculate determinant\n";
        if (rows == 1)
        {
            return data[0][0];
        }
        T result = 0;
        for (int j = 0;j < cols;j++)
            result = result + data[0][j] * cofactor(0, j);
        return result;
    }
    Matrix<T> inverse()
    {
        T det = determinant();
        if (det == 0)
            cout << "\nThe matrix inverse not possible as it is singular\n";

        Matrix<T> resultant(rows, cols);
        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
            {
                resultant.setter(i, j, cofactor(i, j));
            }
        }

        resultant = resultant.transpose();

        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
            {
                resultant.setter(i, j, resultant.getValue(i, j) / det);
            }
        }
        return resultant;
    }
    Matrix<T> scaling(T sx, T sy, T sz)
    {
        //makesure3d
        Matrix<T> ScalingMatrix(3, 3);
        vector<vector<T>>vec = {{sx,0,0},
                                {0,sy,0},
                                {0,0,sz}
        };
        ScalingMatrix.assignVector(vec);

        return ScalingMatrix * (*this);
    }
    Matrix<T> translation(T tx, T ty, T tz)
    {
        Matrix<T> translationMatrix(4, 4);
        vector<vector<T>>vec = {{1,0,0,tx},
                                {0,1,0,ty},
                                {0,0,1,tz},
                                {0,0,0,1},
        };
        translationMatrix.assignVector(vec);

        //copy our matrix data in temp and add a unit row at end
        vector<vector<T>> temp = data;

        vector<T> unit = vector<T>(cols, 1);
        temp.push_back(unit);

        Matrix<T> resultant(4, cols);
        resultant.assignVector(temp);
        resultant = translationMatrix * resultant; 
        
        //remove the extra unit row at end and return result
        resultant.data.pop_back();
        resultant.rows--;
        return resultant;
    }
    Matrix<T> skewingX(T sy, T sz)
    {
        Matrix<T> SkewingMatrix(3, 3);
        vector<vector<T>>vec = {{1,0,0},
                                {sy,1,0},
                                {sz,0,1}
        };
        SkewingMatrix.assignVector(vec);

        return SkewingMatrix * (*this);
    }
    Matrix<T> skewingY(T sx, T sz)
    {
        Matrix<T> SkewingMatrix(3, 3);
        vector<vector<T>>vec = {{1,sx,0},
                                {0,1,0},
                                {0,sz,1}
        };
        SkewingMatrix.assignVector(vec);

        return SkewingMatrix * (*this);
    }
    Matrix<T> skewingZ(T sx, T sy)
    {
        Matrix<T> SkewingMatrix(3, 3);
        vector<vector<T>>vec = {{1,0,sx},
                                {0,1,sy},
                                {0,0,1}
        };
        SkewingMatrix.assignVector(vec);

        return SkewingMatrix * (*this);
    }
    Matrix<T> rotationX(double angleFromX)
    {
        Matrix<T> rotationMatrix(3, 3);
        vector<vector<T>>vec = {{1,0,0},
                                {0,cos(angleFromX),-sin(angleFromX)},
                                {0,sin(angleFromX),cos(angleFromX)}
        };
        rotationMatrix.assignVector(vec);

        return rotationMatrix * (*this);
    }
    Matrix<T> rotationY(double angleFromY)
    {
        Matrix<T> rotationMatrix(3, 3);
        vector<vector<T>>vec = { {cos(angleFromY),0,sin(angleFromY)},
                                {0,1,0},
                                {-sin(angleFromY),0,cos(angleFromY)}
        };
        rotationMatrix.assignVector(vec);

        return rotationMatrix * (*this);
    }
    Matrix<T> rotationZ(double angleFromZ)
    {
        Matrix<T> rotationMatrix(3, 3);
        vector<vector<T>>vec = {
                                {cos(angleFromZ),-sin(angleFromZ),0},
                                {sin(angleFromZ),cos(angleFromZ),0},
                                {0,0,1}
        };
        rotationMatrix.assignVector(vec);

        return rotationMatrix * (*this);
    }
};

