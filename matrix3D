#include <iostream>

#include <vector>

using namespace std;

template <typename T>
class Matrix {
protected:
    int rows;
    int cols;
    vector<vector<T>> data;
public:
    int getRows()
    {
        return rows;
    }
    int getCols()
    {
        return cols;
    }

    T getValue(int rowInd, int colInd)
    {
        return data[rowInd][colInd];
    }
    //param. constructor
    Matrix(int rows, int cols)
    {
        this->rows = rows;
        this->cols = cols;
        data = vector<vector<T>>(rows, vector<T>(cols, 0));
    }

    //addition operator
    Matrix<T> operator +(const Matrix<T>& second)
    {
        Matrix<T> res(rows, cols);
        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
                res.data[i][j] = this->data[i][j] + second.data[i][j];
        }
        return res;
    }

    //subtraction operator
    Matrix<T> operator -(const Matrix<T>& second)
    {
        Matrix<T> res(rows, cols);
        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
                res.data[i][j] = this->data[i][j] - second.data[i][j];
        }
        return res;
    }

    //multiplication operator
    Matrix<T> operator *(const Matrix<T>& second)
    {
        if (cols != second.rows)
            ;//handle

        Matrix<T> res(rows, second.cols);

        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < second.cols; j++)
            {
                res.data[i][j] = 0;//init to zero
                for (int k = 0; k < cols; k++)
                {
                    res.data[i][j] += this->data[i][k] * second.data[k][j];

                }

            }
        }
        return res;
    }

    //scalar multiplication operator
    Matrix<T> operator *(const int scale)
    {
        Matrix<T> res(rows, cols);

        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
            {
                res.data[i][j] = data[i][j] * scale;
            }
        }
        return res;
    }

    //transposing matrix
    Matrix<T> transpose()
    {
        Matrix<T> transp(cols, rows);
        for (int i = 0; i < rows; i++)
            for (int j = 0; j < cols; j++)
                transp.data[j][i] = data[i][j];

        return transp;
    }

    //if matrix used to denote coordinates them by a degree(anticlock)
    Matrix<T> angleRotation(double angleRad)
    {
        if (rows != 2);//throw error as currently only for 2d point cordinates 

        vector<vector<double>> rotationVect2d = { {cos(angleRad),-sin(angleRad)},{sin(angleRad),cos(angleRad)} };

        Matrix<double> result(rows, cols);
        Matrix<double> temp(2, 2);//if 2d then 2x2
        temp.assignVector(rotationVect2d);

        result = temp * (*this);
        return result;
    }

    //rotate matrix by 90 deg.
    Matrix<T> rotation()
    {
        //first transpose
        Matrix<T> rotatedMatrix = transpose();

        //then swap columns from beg. and end
        for (int begCol = 0, endCol = rotatedMatrix.cols - 1; begCol < endCol; begCol++, endCol--)
        {
            for (int i = 0; i < rotatedMatrix.rows; i++)
            {
                swap(rotatedMatrix[i][begCol], rotatedMatrix[i][endCol]);
            }
        }


    }

    bool isSquare()
    {
        return rows == cols;
    }

    //displaying matrix content
    void print()
    {
        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
                cout << round(data[i][j]) << "  ";

            cout << "\n";
        }
        cout << "\n";
    }
    void setter(int rowInd, int colInd, T value)
    {
        data[rowInd][colInd] = value;
    }
    void assignVector(vector<vector<T>>& assignVector)
    {
        for (int i = 0; i < assignVector.size(); i++)
        {
            for (int j = 0; j < assignVector[0].size(); j++)
                this->setter(i, j, assignVector[i][j]);
        }
    }

    T calcCoFactor(int iRow, int jCol)
    {
        if (!isSquare())
            ;//handle

        T result = 0;

        Matrix<T> subMatrix(rows - 1, cols - 1);
        int subRowIndex = 0;
        for (int i = 0; i < rows; i++)
        {
            if (i == iRow)continue;

            int subColIndex = 0;
            
            for (int j = 0; j < cols; j++)
            {

                if (j == jCol)continue;

                //cout << "row:" << i << " col:" << j << " sRow:" << subRowIndex << " subcol:" << subColIndex << ",\n";
                subMatrix.setter(subRowIndex, subColIndex, data[i][j]);
                subColIndex++;
            }
            subRowIndex++;
        }
        result = pow(-1, iRow + jCol) * subMatrix.calcDeterminant();
        return result;
    }

    T calcDeterminant()
    {
        if (!isSquare())
            ;//handle

        if (rows == 1)
        {
            return data[0][0];
        }

        T result = 0;
        for(int j=0;j<cols;j++)
            result = result + data[0][j]*calcCoFactor(0,j);

        return result;
    }

    Matrix<T> inverse()
    {
        T determinant = calcDeterminant();
        if (determinant == 0)
            ;//handle

        Matrix<T> resultant(rows, cols);
        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
            {
                resultant.setter(i, j, calcCoFactor(i, j));
            }
        }

        resultant = resultant.transpose();

        for (int i = 0; i < rows; i++)
        {
            for (int j = 0; j < cols; j++)
            {
                resultant.setter(i, j, resultant.getValue(i, j) / determinant);
            }
        }
        return resultant;
    }

    Matrix<T> scaling(T x, T y, T z)
    {
        //makesure3d
        Matrix transformationMatrix(3, 3);
        vector<vector<T>>vec=  {{x,0,0},
                                {0,y,0},
                                {0,0,z}
        };
        transformationMatrix.assignVector(vec);

        return transformationMatrix * (*this);
    }
    


};

